<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sorting_project.MainController" prefHeight="700.0" prefWidth="1000.0">

    <top>
        <HBox spacing="0" prefHeight="50.0" style="-fx-background-color: #333; -fx-border-color: #222; -fx-border-width: 0 0 1 0;">
            <Button fx:id="btnTabComparison" text="Comparison Mode" onAction="#showComparisonMode"
                    prefHeight="50.0" prefWidth="200.0" style="-fx-background-radius: 0; -fx-background-color: #444; -fx-text-fill: white;"/>
            <Button fx:id="btnTabVisualizer" text="Visualization Mode" onAction="#showVisualizerMode"
                    prefHeight="50.0" prefWidth="200.0" style="-fx-background-radius: 0; -fx-background-color: #333; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentStack">
            <VBox fx:id="viewComparison" spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="Performance Benchmarks" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <TableView fx:id="tableResults" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" text="Algorithm" prefWidth="150"/>
                        <TableColumn fx:id="colAvg" text="Avg (ms)" prefWidth="100"/>
                        <TableColumn fx:id="colMin" text="Min (ms)" prefWidth="100"/>
                        <TableColumn fx:id="colMax" text="Max (ms)" prefWidth="100"/>
                        <TableColumn fx:id="colComp" text="Comparisons" prefWidth="120"/>
                        <TableColumn fx:id="colInt" text="Interchanges" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="viewVisualizer" spacing="15" visible="false" managed="false">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <HBox spacing="20" alignment="CENTER">
                    <Label fx:id="lblVisComp" text="Comparisons: 0" style="-fx-text-fill: #2196F3; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    <Label fx:id="lblVisInter" text="Interchanges: 0" style="-fx-text-fill: #F44336; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                <Pane fx:id="paneCanvas" VBox.vgrow="ALWAYS" style="-fx-background-color: #1e1e1e; -fx-border-color: #333; -fx-border-radius: 5; -fx-background-radius: 5;"/>
            </VBox>
        </StackPane>
    </center>

    <right>
        <StackPane fx:id="settingsStack" prefWidth="250.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #ccc; -fx-border-width: 0 0 0 1;">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <VBox fx:id="settingsComparison" spacing="15">
                <Label text="Comparison Controls" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Separator/>
                <Label text="Array Size:"/>
                <TextField fx:id="txtSize" text="1000"/>
                <Label text="Initial State:"/>
                <ComboBox fx:id="comboType" prefWidth="210.0"/>

                <Button text="Load from File" onAction="#handleOpenFile" maxWidth="Infinity"/>
                <Label fx:id="lblFileStatusComparison" text="No file loaded"
                       style="-fx-text-fill: gray; -fx-font-style: italic;" wrapText="true"/>

                <Separator/>
                <Label text="Select Algorithms to Run:"/>
                <CheckBox fx:id="chkBubble" text="Bubble Sort" selected="true"/>
                <CheckBox fx:id="chkSelection" text="Selection Sort" selected="true"/>
                <CheckBox fx:id="chkInsertion" text="Insertion Sort" selected="true"/>
                <CheckBox fx:id="chkQuick" text="Quick Sort" selected="true"/>
                <CheckBox fx:id="chkMerge" text="Merge Sort" selected="true"/>
                <CheckBox fx:id="chkHeap" text="Heap Sort" selected="true"/>

                <Button text="Run Selected Algorithms" onAction="#handleRunComparison"
                        maxWidth="Infinity" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </VBox>

            <VBox fx:id="settingsVisualizer" spacing="15" visible="false" managed="false">
                <Label text="Visualizer Controls" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Separator/>
                <Label text="Algorithm:"/>
                <ComboBox fx:id="comboVisualAlgo" prefWidth="210.0"/>
                <Label text="Input Source:"/>
                <ComboBox fx:id="comboVisualSource" prefWidth="210.0"/>
                <Button fx:id="btnSelectFileVisual" text="Select File" onAction="#handleOpenFile"
                        maxWidth="Infinity" visible="false" managed="false" />
                <Label fx:id="lblFileStatus" text="No file loaded"
                       style="-fx-text-fill: gray; -fx-font-style: italic;" wrapText="true"/>
                <Label text="Number of Elements (Max 100):"/>
                <TextField fx:id="txtVisualCount" text="50" promptText="Enter 1-100"/>
                <Label text="Animation Speed (1-100):"/>
                <Slider fx:id="sliderSpeed" min="1" max="100" value="50" showTickLabels="true"/>
                <Button text="Start Animation" onAction="#handleStartAnimation" maxWidth="Infinity"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Reset Visual" onAction="#handleResetVisualizer" maxWidth="Infinity"/>
            </VBox>
        </StackPane>
    </right>
</BorderPane>
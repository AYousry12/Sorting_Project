<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sorting_project.MainController" prefHeight="600.0" prefWidth="900.0">

    <left>
        <VBox spacing="15.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Configuration" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

            <Label text="Array Size:"/>
            <TextField fx:id="txtSize" text="1000"/>

            <Label text="Array Type:"/>
            <ComboBox fx:id="comboType" prefWidth="150.0"/>

            <Separator/>

            <Button fx:id="btnRun" text="Run Comparison" onAction="#handleRunComparison" maxWidth="Infinity" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            <Button fx:id="btnOpenFile" text="Open TXT File" onAction="#handleOpenFile" maxWidth="Infinity"/>

            <Separator/>

            <Button text="Switch to Visualizer" onAction="#handleSwitchMode" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane>
            <VBox fx:id="viewComparison" spacing="10">
            </VBox>

            <VBox fx:id="viewVisualizer" spacing="10" visible="false">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Start Animation" onAction="#handleStartAnimation"/>
                    <Button text="Reset" onAction="#handleResetVisualizer"/>
                    <Slider fx:id="sliderSpeed" min="1" max="100" value="50"/>
                    <Label text="Speed"/>
                </HBox>
                <Pane fx:id="paneCanvas" VBox.vgrow="ALWAYS" style="-fx-background-color: #222222; -fx-border-color: #444444;"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>